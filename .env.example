# Copie para .env apenas no ambiente de deploy, nunca commite o .env real.

# Use a connection string do Supabase em:
# Project Settings > Database > Connection string
# Recomendado para deploy: Transaction pooler ou Session pooler.
SUPABASE_DB_URL=postgresql://postgres.PROJECT_REF:SENHA@HOST:6543/postgres?sslmode=require

# Opcional. Se nao definir, o app usa p1_lucio/resultados.db localmente.
# DATABASE_URL=postgresql://postgres.PROJECT_REF:SENHA@HOST:6543/postgres?sslmode=require
